---
// Landing.astro — Playful, colorful landing for cloudflared-project docs
---

<div class="land">
  <!-- Decorative background -->
  <div class="land__bg" aria-hidden="true">
    <div class="land__blob land__blob--1"></div>
    <div class="land__blob land__blob--2"></div>
    <div class="land__blob land__blob--3"></div>
    <div class="land__grid"></div>
    <div class="land__noise"></div>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__badge">
      <span class="hero__badge-icon">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </span>
      <span>Open Source CLI Tool</span>
    </div>

    <h1 class="hero__title">
      <span class="hero__line hero__line--1">Cloudflare Tunnels,</span>
      <span class="hero__line hero__line--2">finally <span class="hero__gradient">tamed.</span></span>
    </h1>

    <p class="hero__sub">
      Project-aware config, multi-environment deploys, and full lifecycle management — all from one beautiful CLI.
    </p>

    <div class="hero__actions">
      <a href="/guides/installation/" class="btn btn--rainbow">
        <span>Get Started</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="https://github.com/MakFly/cloudflared-cli" class="btn btn--glass">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        <span>GitHub</span>
      </a>
    </div>
  </section>

  <!-- Terminal -->
  <section class="terminal-wrap">
    <div class="terminal">
      <div class="terminal__glow"></div>
      <div class="terminal__chrome">
        <div class="terminal__dots">
          <span></span><span></span><span></span>
        </div>
        <div class="terminal__tab">cloudflared-project</div>
      </div>
      <div class="terminal__body">
        <div class="tl tl--1">
          <span class="t-p">~</span>
          <span class="t-cmd">cloudflared-project</span>
          <span class="t-arg">init</span>
          <span class="t-val">myapp</span>
          <span class="t-flag">--domain</span>
          <span class="t-val">app.example.com</span>
        </div>
        <div class="tl tl--2">
          <span class="t-check">&#10003;</span>
          <span class="t-txt">Project <strong>myapp</strong> initialized</span>
        </div>
        <div class="tl tl--3">
          <span class="t-arrow">&#8594;</span>
          <span class="t-dim">~/.cloudflared/projects/myapp</span>
        </div>
        <div class="tl tl--4">
          <span class="t-p">~</span>
          <span class="t-cmd">cloudflared-project</span>
          <span class="t-flag">-p</span>
          <span class="t-val">myapp</span>
          <span class="t-arg">deploy</span>
          <span class="t-flag">--route-dns</span>
        </div>
        <div class="tl tl--5">
          <span class="t-check">&#10003;</span>
          <span class="t-txt">Config validated</span>
          <span class="t-badge">dev</span>
        </div>
        <div class="tl tl--6">
          <span class="t-check">&#10003;</span>
          <span class="t-txt">DNS routed</span>
          <span class="t-val-i">app.example.com</span>
        </div>
        <div class="tl tl--7">
          <span class="t-check">&#10003;</span>
          <span class="t-txt">Tunnel connected</span>
          <span class="t-dim">&#183; 4 connections &#183; Paris (CDG)</span>
        </div>
        <div class="tl tl--8">
          <span class="t-p">~</span>
          <span class="t-cursor"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="features__header">
      <span class="section-label">Features</span>
      <h2 class="features__title">Everything you need to ship tunnels with confidence</h2>
    </div>

    <div class="features__grid">
      <div class="card card--purple">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        </div>
        <h3 class="card__title">Project-aware</h3>
        <p class="card__desc">Isolated configs per project in <code>~/.cloudflared/projects/</code>. No more tangled YAML sprawl.</p>
      </div>

      <div class="card card--blue">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16v16H4z"/><path d="M4 12h16M12 4v16"/></svg>
        </div>
        <h3 class="card__title">Multi-environment</h3>
        <p class="card__desc">Dev, staging, prod &mdash; each with its own ingress rules, tunnel IDs, and credentials.</p>
      </div>

      <div class="card card--orange">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="card__title">Full lifecycle</h3>
        <p class="card__desc">Init, create, configure, validate, deploy, monitor, teardown &mdash; every step covered.</p>
      </div>

      <div class="card card--green">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="card__title">Production-ready</h3>
        <p class="card__desc">Graceful shutdown, PID management, config validation, detached mode. Ship with confidence.</p>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="arch">
    <div class="arch__header">
      <span class="section-label">How it works</span>
      <h2 class="arch__title">From your app to the edge, in one command</h2>
    </div>

    <div class="arch__flow">
      <div class="arch__node">
        <div class="arch__icon arch__icon--blue">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <span class="arch__name">Your App</span>
        <span class="arch__meta">localhost:8080</span>
      </div>

      <div class="arch__line">
        <div class="arch__line-track"></div>
        <div class="arch__line-pulse"></div>
      </div>

      <div class="arch__node arch__node--main">
        <div class="arch__icon arch__icon--gradient">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <span class="arch__name">cloudflared-project</span>
        <span class="arch__meta">init &middot; config &middot; deploy</span>
      </div>

      <div class="arch__line arch__line--encrypted">
        <div class="arch__line-track"></div>
        <div class="arch__line-pulse"></div>
        <span class="arch__line-label">encrypted</span>
      </div>

      <div class="arch__node">
        <div class="arch__icon arch__icon--orange">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
        </div>
        <span class="arch__name">Cloudflare Edge</span>
        <span class="arch__meta">app.example.com</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta__inner">
      <div class="cta__bg"></div>
      <h2 class="cta__title">Ready to simplify your tunnel workflow?</h2>
      <p class="cta__sub">Get up and running in under two minutes.</p>
      <div class="cta__actions">
        <a href="/guides/quickstart/" class="btn btn--rainbow btn--lg">
          <span>Quick Start Guide</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/reference/commands/" class="btn btn--glass">
          <span>Command Reference</span>
        </a>
      </div>
    </div>
  </section>
</div>

<style>
  /* ═══════════════════════════════════════
     FONTS
     ═══════════════════════════════════════ */
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');

  /* ═══════════════════════════════════════
     TOKENS
     ═══════════════════════════════════════ */
  .land {
    --bg: #0a0a0f;
    --surface: rgba(255, 255, 255, 0.03);
    --border: rgba(255, 255, 255, 0.08);
    --text: #a1a1aa;
    --text-dim: #52525b;
    --heading: #fafafa;

    --purple: #a855f7;
    --purple-dim: rgba(168, 85, 247, 0.12);
    --blue: #3b82f6;
    --blue-dim: rgba(59, 130, 246, 0.12);
    --orange: #f97316;
    --orange-dim: rgba(249, 115, 22, 0.12);
    --green: #22c55e;
    --green-dim: rgba(34, 197, 94, 0.12);
    --pink: #ec4899;
    --teal: #14b8a6;

    --font: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', monospace;
    --radius: 16px;
    --radius-sm: 10px;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ═══════════════════════════════════════
     BASE
     ═══════════════════════════════════════ */
  .land {
    position: relative;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    overflow: hidden;
    padding: 0 1.5rem;
  }

  /* ═══════════════════════════════════════
     BACKGROUND
     ═══════════════════════════════════════ */
  .land__bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .land__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: float 20s ease-in-out infinite;
  }

  .land__blob--1 {
    width: 600px;
    height: 600px;
    top: -200px;
    left: 20%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.15), transparent 70%);
  }

  .land__blob--2 {
    width: 500px;
    height: 500px;
    top: -100px;
    right: 10%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.12), transparent 70%);
    animation-delay: -7s;
  }

  .land__blob--3 {
    width: 400px;
    height: 400px;
    bottom: 30%;
    left: -100px;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.08), transparent 70%);
    animation-delay: -14s;
  }

  .land__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 50% at 50% 0%, black 30%, transparent 100%);
  }

  .land__noise {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  }

  /* ═══════════════════════════════════════
     SECTION LABEL
     ═══════════════════════════════════════ */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: linear-gradient(135deg, var(--purple), var(--blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  /* ═══════════════════════════════════════
     HERO
     ═══════════════════════════════════════ */
  .hero {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding-top: clamp(4rem, 12vh, 8rem);
    text-align: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem 0.4rem 0.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple-dim), var(--blue-dim));
    border: 1px solid rgba(168, 85, 247, 0.15);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--purple);
    margin-bottom: 2rem;
    animation: fadeUp 0.5s var(--ease) both;
    transition: border-color 0.3s, transform 0.3s;
  }

  .hero__badge:hover {
    border-color: rgba(168, 85, 247, 0.3);
    transform: translateY(-1px);
  }

  .hero__badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--purple), var(--blue));
    color: white;
  }

  .hero__title {
    font-family: var(--font);
    font-size: clamp(2.6rem, 6.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.08;
    color: var(--heading);
    letter-spacing: -0.04em;
    margin: 0 0 1.5rem;
  }

  .hero__line {
    display: block;
  }

  .hero__line--1 {
    animation: fadeUp 0.5s var(--ease) 0.1s both;
  }

  .hero__line--2 {
    animation: fadeUp 0.5s var(--ease) 0.15s both;
  }

  .hero__gradient {
    background: linear-gradient(135deg, var(--orange) 0%, var(--pink) 40%, var(--purple) 70%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% auto;
    animation: fadeUp 0.5s var(--ease) 0.15s both, shimmer 4s linear infinite;
  }

  .hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    animation: fadeUp 0.5s var(--ease) 0.2s both;
  }

  .hero__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 0.5s var(--ease) 0.25s both;
  }

  /* ═══════════════════════════════════════
     BUTTONS
     ═══════════════════════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s var(--ease);
    cursor: pointer;
    position: relative;
    border: none;
  }

  .btn--rainbow {
    background: linear-gradient(135deg, var(--purple), var(--blue));
    color: white;
    box-shadow:
      0 2px 12px rgba(168, 85, 247, 0.25),
      0 0 0 1px rgba(168, 85, 247, 0.2) inset;
  }

  .btn--rainbow:hover {
    box-shadow:
      0 4px 24px rgba(168, 85, 247, 0.4),
      0 0 0 1px rgba(168, 85, 247, 0.3) inset;
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  .btn--glass {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
    border: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }

  .btn--glass:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--heading);
    transform: translateY(-1px);
  }

  .btn--lg {
    padding: 0.8rem 1.8rem;
    font-size: 0.92rem;
  }

  /* ═══════════════════════════════════════
     TERMINAL
     ═══════════════════════════════════════ */
  .terminal-wrap {
    position: relative;
    z-index: 1;
    max-width: 660px;
    margin: 3.5rem auto 0;
    animation: fadeUp 0.6s var(--ease) 0.35s both;
  }

  .terminal {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(20px);
    box-shadow:
      0 8px 40px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.03) inset;
  }

  .terminal__glow {
    position: absolute;
    inset: -1px;
    border-radius: var(--radius);
    background: linear-gradient(135deg, var(--purple-dim), transparent 40%, transparent 60%, var(--blue-dim));
    z-index: -1;
    opacity: 0.6;
  }

  .terminal__chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.2rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
  }

  .terminal__dots {
    display: flex;
    gap: 6px;
  }

  .terminal__dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .terminal__dots span:nth-child(1) { background: #ff5f57; }
  .terminal__dots span:nth-child(2) { background: #febc2e; }
  .terminal__dots span:nth-child(3) { background: #28c840; }

  .terminal__tab {
    flex: 1;
    text-align: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-right: 36px;
  }

  .terminal__body {
    padding: 1.25rem 1.5rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    line-height: 1.9;
  }

  .tl {
    white-space: nowrap;
    overflow: hidden;
  }

  .tl--1 { animation: typeIn 0.4s ease 0.6s both; }
  .tl--2 { animation: typeIn 0.3s ease 1.1s both; }
  .tl--3 { animation: typeIn 0.3s ease 1.3s both; }
  .tl--4 { animation: typeIn 0.4s ease 1.9s both; }
  .tl--5 { animation: typeIn 0.3s ease 2.4s both; }
  .tl--6 { animation: typeIn 0.3s ease 2.6s both; }
  .tl--7 { animation: typeIn 0.3s ease 2.8s both; }
  .tl--8 { animation: typeIn 0.3s ease 3.2s both; }

  .t-p { color: var(--purple); margin-right: 0.5em; font-weight: 600; }
  .t-cmd { color: var(--heading); font-weight: 500; }
  .t-arg { color: var(--teal); margin-left: 0.4em; }
  .t-val { color: var(--orange); margin-left: 0.4em; }
  .t-val-i { color: var(--orange); margin-left: 0.4em; font-style: italic; }
  .t-flag { color: var(--blue); margin-left: 0.4em; }
  .t-check { color: var(--green); margin-right: 0.3em; font-weight: 700; }
  .t-arrow { color: var(--blue); margin-right: 0.3em; }
  .t-txt { color: var(--text); }
  .t-txt strong { color: var(--heading); }
  .t-dim { color: var(--text-dim); margin-left: 0.3em; }
  .t-badge {
    display: inline-block;
    background: var(--purple-dim);
    color: var(--purple);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.05em 0.5em;
    border-radius: 4px;
    margin-left: 0.5em;
  }

  .t-cursor {
    display: inline-block;
    width: 8px;
    height: 1.1em;
    background: linear-gradient(180deg, var(--purple), var(--blue));
    vertical-align: text-bottom;
    border-radius: 1px;
    animation: blink 1.2s ease-in-out infinite;
  }

  /* ═══════════════════════════════════════
     FEATURES
     ═══════════════════════════════════════ */
  .features {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 6rem auto 0;
    animation: fadeUp 0.5s var(--ease) 0.4s both;
  }

  .features__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .features__title {
    font-family: var(--font);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--heading);
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.2;
    max-width: 500px;
    margin-inline: auto;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .card {
    position: relative;
    padding: 1.75rem;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    transition: all 0.35s var(--ease);
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
